# LLM Backend — set one (or both)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default backend: "openai" or "anthropic"
LLM_BACKEND=openai

# Model names (optional overrides)
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings backend: "openai" or "huggingface"
# huggingface requires no API key and works offline
EMBEDDINGS_BACKEND=huggingface

# Path where the FAISS index is stored
FAISS_INDEX_PATH=./faiss_index

# Knowledge base directory
KNOWLEDGE_BASE_PATH=./knowledge_base
